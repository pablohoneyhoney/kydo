# Copy to .env.local and fill in. Used by server.js in Phase 2+.
# Never commit .env.local.

# Phase 3 — Anthropic for question generation + judge
ANTHROPIC_API_KEY=

# Phase 2 — OpenAI Whisper for chunked transcription
OPENAI_API_KEY=

# Optional model overrides (defaults below)
KYDO_GENERATOR_MODEL=claude-sonnet-4-5
KYDO_JUDGE_MODEL=claude-haiku-4-5

# Optional: override timing for dev testing (production uses 5 min)
KYDO_CYCLE_SECONDS=300
KYDO_QUESTION_HOLD_SECONDS=60
